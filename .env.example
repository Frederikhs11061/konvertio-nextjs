# Copy to .env.local and fill in. Never commit .env.local or expose keys client-side.
# See: https://nextjs.org/docs/app/building-your-application/configuring/environment-variables

# Required: Contact form email via Resend. Only use server-side in API routes.
# Get your key at: https://resend.com/api-keys
RESEND_API_KEY=

# Optional: For distributed rate limiting (multi-instance / DDoS), use Upstash Redis.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
